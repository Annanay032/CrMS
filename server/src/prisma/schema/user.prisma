// ─── Auth & Users ────────────────────────────────────────────

enum Role {
  CREATOR
  BRAND
  AGENCY
  ADMIN
}

enum OAuthProvider {
  GOOGLE
  INSTAGRAM
  YOUTUBE
  TIKTOK
  TWITTER
  LINKEDIN
  THREADS
  BLUESKY
  FACEBOOK
  PINTEREST
  MASTODON
  MICROSOFT
  OKTA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String
  avatarUrl    String?
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  oauthAccounts    OAuthAccount[]
  creatorProfile   CreatorProfile?
  brandProfile     BrandProfile?
  agencyProfile    AgencyProfile?
  agentTasks       AgentTask[]
  listeningQueries ListeningQuery[]
  competitors      Competitor[]
  savedReplies     SavedReply[]
  voiceProfile     UserVoiceProfile?
  analyticsReports AnalyticsReport[]
  ownedTeams       Team[]
  teamMembers      TeamMember[]
  postComments     PostComment[]
  postActivityLogs PostActivityLog[]
  startPages       StartPage[]
  notifications    Notification[]
  usageBudget      UsageBudget?
  subscription     Subscription?
  userSettings     UserSettings?
  apiKeys          ApiKey[]
  invitesSent      Invite[]     @relation("InvitesSent")
  invitesAccepted  Invite[]     @relation("InvitesAccepted")

  @@map("users")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invite {
  id          String       @id @default(cuid())
  email       String
  role        Role
  token       String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String
  acceptedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  invitedBy  User  @relation("InvitesSent", fields: [invitedById], references: [id])
  acceptedBy User? @relation("InvitesAccepted", fields: [acceptedById], references: [id])

  @@index([token])
  @@index([email])
  @@map("invites")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  accessToken       String // encrypted at rest via app layer
  refreshToken      String? // encrypted at rest via app layer
  expiresAt         DateTime?
  paused            Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model UserSettings {
  id                    String    @id @default(cuid())
  userId                String    @unique

  // ── Data Refresh ──
  listeningFrequency    Int       @default(1)  // polls per day
  competitiveFrequency  Int       @default(1)

  // ── Notifications ──
  emailDigest           Boolean   @default(true)
  pushNotifications     Boolean   @default(true)
  notifyNewFollower     Boolean   @default(true)
  notifyMention         Boolean   @default(true)
  notifyCampaignUpdate  Boolean   @default(true)
  notifyCommentReply    Boolean   @default(true)

  // ── Publishing Defaults ──
  defaultPlatform       String?                // e.g. "INSTAGRAM"
  defaultPostType       String?                // e.g. "REEL"
  defaultHashtags       String[]  @default([]) // auto-appended
  autoSchedule          Boolean   @default(false)
  timezone              String    @default("UTC")

  // ── AI Preferences ──
  aiTone                String    @default("friendly")
  aiLanguage            String    @default("en")
  aiAutoSuggest         Boolean   @default(true)

  // ── Privacy & Security ──
  profileVisibility     String    @default("public") // public | private | connections-only
  showAnalytics         Boolean   @default(true)     // show analytics on public profile

  // ── Web Push ──
  pushSubscription      Json?     // serialized PushSubscription object

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model UserVoiceProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  tonePreferences String[] // e.g. ["friendly", "casual", "witty"]
  exampleReplies  String[]
  vocabulary      String[] // frequently used words/phrases
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_voice_profiles")
}

// ─── API Keys (Public API) ──────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]  @default(["read"])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}
