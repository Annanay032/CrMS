# ── Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api

# ── Database (Postgres)
DATABASE_URL=postgresql://crms:crms_secret@localhost:5432/crms_db?schema=public

# ── Redis
REDIS_URL=redis://localhost:6379

# ── JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption (AES-256-GCM for OAuth tokens at rest)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Instagram Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:3001/api/auth/instagram/callback

# ── YouTube Data API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CALLBACK_URL=http://localhost:3001/api/auth/youtube/callback

# ── TikTok API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_CALLBACK_URL=http://localhost:3001/api/accounts/callback/tiktok

# ── Twitter / X API (OAuth 2.0)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3001/api/accounts/callback/twitter

# ── LinkedIn API
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3001/api/accounts/callback/linkedin

# ── Facebook API
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/accounts/callback/facebook

# ── Pinterest API
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_CALLBACK_URL=http://localhost:3001/api/accounts/callback/pinterest

# ── Mastodon API
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
MASTODON_CALLBACK_URL=http://localhost:3001/api/accounts/callback/mastodon

# ── OpenAI (or compatible API like Gemini)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
# For Gemini: set OPENAI_API_KEY to your Gemini key, OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai, OPENAI_MODEL=gemini-2.0-flash

# ── Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=

# ── Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# ── File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
