// ─── Generator & Datasource ──────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Shared Enums ────────────────────────────────────────────

enum Platform {
  INSTAGRAM
  YOUTUBE
  TIKTOK
  TWITTER
  LINKEDIN
  THREADS
  BLUESKY
  FACEBOOK
  PINTEREST
}
