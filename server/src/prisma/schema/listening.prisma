// ─── Social Listening ────────────────────────────────────────

enum MentionSentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
  MIXED
}

enum MentionIntent {
  BUYING
  QUESTION
  COMPLAINT
  PRAISE
  COLLAB
  OTHER
}

enum SignalType {
  TREND
  LEAD
  RISK
  VIRAL_POST
}

enum SignalStatus {
  NEW
  ACTIONED
  IGNORED
}

model ListeningQuery {
  id         String   @id @default(cuid())
  userId     String
  name       String
  keywords   String[]
  platforms  Platform[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentions  Mention[]
  snapshots SentimentSnapshot[]

  @@index([userId, isActive])
  @@map("listening_queries")
}

model Mention {
  id              String           @id @default(cuid())
  queryId         String
  platform        Platform
  source          String?          // username or account handle
  content         String
  url             String?
  sentiment       MentionSentiment @default(NEUTRAL)
  reach           Int              @default(0)
  intent          MentionIntent?
  urgencyScore    Int              @default(0) // 0-100
  influenceScore  Int              @default(0) // 0-100
  opportunityScore Int             @default(0) // 0-100
  isConverted     Boolean          @default(false) // moved to CRM
  authorFollowers Int              @default(0)
  createdAt       DateTime         @default(now())
  detectedAt      DateTime         @default(now())

  query   ListeningQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  signals Signal[]

  @@index([queryId, sentiment])
  @@index([queryId, platform])
  @@index([queryId, intent])
  @@index([detectedAt])
  @@index([opportunityScore])
  @@map("mentions")
}

model Signal {
  id               String       @id @default(cuid())
  userId           String
  type             SignalType
  title            String
  description      String?
  sourceMentionId  String?
  opportunityScore Int          @default(0) // 0-100
  status           SignalStatus @default(NEW)
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMention Mention? @relation(fields: [sourceMentionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, type])
  @@index([opportunityScore])
  @@map("signals")
}

model SentimentSnapshot {
  id            String   @id @default(cuid())
  queryId       String
  date          DateTime @db.Date
  positiveCount Int      @default(0)
  negativeCount Int      @default(0)
  neutralCount  Int      @default(0)
  mixedCount    Int      @default(0)
  totalVolume   Int      @default(0)

  query ListeningQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@unique([queryId, date])
  @@map("sentiment_snapshots")
}
