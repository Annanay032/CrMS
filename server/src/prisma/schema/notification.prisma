// ─── Notifications ───────────────────────────────────────────

enum NotificationType {
  AGENT_COMPLETED
  AGENT_FAILED
  TREND_ALERT
  MENTION
  APPROVAL_REQUEST
  APPROVAL_RESOLVED
  CAMPAIGN_UPDATE
  COMMENT_SPIKE
  SYSTEM
  DAILY_RECOMMENDATION
  BRAND_INQUIRY
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}
