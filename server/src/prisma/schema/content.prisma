// ─── Content & Scheduling ────────────────────────────────────

enum PostStatus {
  IDEA
  DRAFT
  REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
  PENDING_MANUAL
}

enum PostType {
  IMAGE
  VIDEO
  REEL
  STORY
  CAROUSEL
  SHORT
  THREAD
}

enum IdeaStatus {
  SPARK
  DEVELOPING
  READY
  ARCHIVED
}

model ContentIdea {
  id               String     @id @default(cuid())
  creatorProfileId String
  title            String
  body             String?
  status           IdeaStatus @default(SPARK)
  source           String?    // manual | ai | rss | trend
  mediaUrls        String[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  tags           ContentIdeaTag[]

  @@index([creatorProfileId, status])
  @@map("content_ideas")
}

model ContentTag {
  id               String   @id @default(cuid())
  creatorProfileId String
  name             String
  color            String   @default("#6366f1") // hex color
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  ideas          ContentIdeaTag[]

  @@unique([creatorProfileId, name])
  @@map("content_tags")
}

model ContentIdeaTag {
  ideaId String
  tagId  String

  idea ContentIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag  ContentTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ideaId, tagId])
  @@map("content_idea_tags")
}

model ContentTemplate {
  id       String   @id @default(cuid())
  name     String
  body     String
  platform Platform?
  category String   // e.g. "tip", "how-to", "behind-the-scenes", "promotion"
  isGlobal Boolean  @default(false) // true = system-provided, false = user-created
  userId   String?  // null for global templates
  createdAt DateTime @default(now())

  @@map("content_templates")
}

model ContentPost {
  id               String          @id @default(cuid())
  creatorProfileId String
  platform         Platform
  postType         PostType
  caption          String?
  hashtags         String[]
  mediaUrls        String[]
  scheduledAt      DateTime?
  publishedAt      DateTime?
  status           PostStatus      @default(DRAFT)
  externalPostId   String?    // ID on the platform after publishing
  firstComment     String?    // Auto first-comment after publishing
  platformOverrides Json?     // { "INSTAGRAM": { caption, hashtags }, "TIKTOK": { caption } }
  bulkGroupId      String?    // Groups posts created from multi-platform compose
  ideaId           String?    // Link back to the idea this was created from
  approvalStatus   ApprovalStatus  @default(NONE)
  teamId           String?

  // ── Threading ──
  parentPostId     String?    // For thread parts, links to the first post in thread
  threadOrder      Int?       // 0-based order within a thread

  // ── Recurring / Evergreen ──
  isRecurring      Boolean    @default(false)
  recurrenceRule   String?    // iCal RRULE e.g. "FREQ=WEEKLY;BYDAY=MO,WE,FR"
  maxRecurrences   Int?       // null = unlimited
  recurrenceCount  Int        @default(0) // how many times this has been re-posted
  lastRecurredAt   DateTime?
  sourcePostId     String?    // If this is a clone, references the original recurring post

  // ── Repost / Retweet ──
  repostSourceUrl  String?    // URL of external post to repost/retweet
  repostType       String?    // "retweet" | "quote" | "boost"

  // ── Boosted / Paid ──
  isBoosted        Boolean    @default(false)
  adSpend          Float?     // amount spent on boosting/promoting

  // ── Media ──
  thumbnailUrl     String?    // Custom thumbnail for video posts

  // ── Reliability ──
  retryCount       Int        @default(0) // number of publish retries attempted
  maxRetries       Int        @default(3)
  lastError        String?    // last publish error message

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  analytics      PostAnalytics?
  team           Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  comments       PostComment[]
  parentPost     ContentPost?   @relation("ThreadParts", fields: [parentPostId], references: [id], onDelete: SetNull)
  threadParts    ContentPost[]  @relation("ThreadParts")

  @@index([creatorProfileId, status])
  @@index([scheduledAt])
  @@index([bulkGroupId])
  @@index([teamId, approvalStatus])
  @@index([parentPostId])
  @@index([isRecurring, status])
  @@map("content_posts")
}

model PostingSchedule {
  id               String   @id @default(cuid())
  creatorProfileId String
  platform         Platform
  dayOfWeek        Int      // 0=Sunday, 6=Saturday
  timeSlot         String   // "HH:MM" 24h format
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, platform, dayOfWeek, timeSlot])
  @@map("posting_schedules")
}

// ─── Calendar Notes ──────────────────────────────────────────

model CalendarNote {
  id               String   @id @default(cuid())
  creatorProfileId String
  date             DateTime @db.Date
  title            String
  description      String?
  color            String   @default("#6366f1") // hex color
  isAllDay         Boolean  @default(true)
  startTime        String?  // "HH:MM" if not all-day
  endTime          String?  // "HH:MM" if not all-day
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId, date])
  @@map("calendar_notes")
}

// ─── RSS Feeds ───────────────────────────────────────────────

model RssFeed {
  id               String   @id @default(cuid())
  creatorProfileId String
  url              String
  title            String?
  isActive         Boolean  @default(true)
  autoCreateIdeas  Boolean  @default(true) // auto-create ContentIdea from new items
  lastFetchedAt    DateTime?
  lastItemGuid     String?  // GUID of last processed item to avoid duplicates
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, url])
  @@map("rss_feeds")
}
